APP_NAME="Sondaggi Moderni"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# --- MySQL (Docker Compose) ---
# Docker Compose legge automaticamente il file `.env` nella directory del progetto per:
#   • interpolazione `${MYSQL_*}` nei file `docker-compose*.yml`;
#   • `env_file: .env` dei servizi app (`web`, `migrate`, `worker`).
# Allinea sempre DB_DATABASE / DB_USERNAME / DB_PASSWORD ai valori MYSQL_* sotto.
MYSQL_DATABASE=sondaggi_db
MYSQL_USER=sondaggi_user
MYSQL_PASSWORD=sondaggi_pass
MYSQL_ROOT_PASSWORD=rootpass_local

# Schema database (Docker / deploy): solo le migrations Laravel (`docker compose` esegue il servizio one-shot `migrate`).
# Nessun DDL in `docker/mysql/init` (evita doppia fonte di verità). Utente demo: `php artisan db:seed` nel container web.

# --- Overlay `docker-compose.prod.yml` (solo VPS; in locale usare docker-compose.dev.yml) ---
# Percorsi host per bind mount (default se omessi: /data/sondaggi/media e /data/sondaggi/logs):
# SONDAGGI_MEDIA_PATH=/data/sondaggi/media
# SONDAGGI_LOGS_PATH=/data/sondaggi/logs
#
# FQDN servito da Traefik (senza https://), obbligatorio con compose prod su VPS:
# SONDAGGI_TRAEFIK_HOST=app.tuodominio.it

# Fuso orario: scadenze e campo datetime-local sono letti come ora locale in questa zona (Italia).
APP_TIMEZONE=Europe/Rome

# Salt per hash IP / rate limit sondaggi pubblici (obbligatorio in produzione)
APP_RESPONSE_SALT=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database: SQLite (solo artisan serve locale) oppure MySQL (Docker / produzione).
# MySQL: allinea utente/db/password a MYSQL_*.
#
# Con Docker (`docker compose`): imposta **DB_HOST=db** (hostname del servizio). I processi worker di
# `php artisan serve` nel container rileggono questo file e non ereditano solo le variabili Compose.
# Da host (artisan / IDE con MySQL su porta 3306 esposta): usa `DB_HOST=127.0.0.1` oppure
#   DB_HOST=127.0.0.1 php artisan migrate
DB_CONNECTION=sqlite
# Esempio MySQL + Docker (decommentare e allineare a MYSQL_* sopra; DB_HOST=db obbligatorio nel container):
# DB_CONNECTION=mysql
# DB_HOST=db
# DB_PORT=3306
# DB_DATABASE=sondaggi_db
# DB_USERNAME=sondaggi_user
# DB_PASSWORD=sondaggi_pass
#
# APP_URL con Docker: stack base `http://127.0.0.1:8000`; con dev override `http://127.0.0.1:18080`

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# Disco predefinito Laravel (le foto profilo usano esplicitamente il disco "public" → storage/app/public).
# Dopo clone/deploy: php artisan storage:link per public/storage → storage/app/public (già nello script composer "setup" e nell'entrypoint Docker).
FILESYSTEM_DISK=local

# Coda: `database` richiede il servizio Docker `worker` (profilo `queue`).
# Impostare COMPOSE_PROFILES=queue nel `.env` così `docker compose up` avvia anche il worker.
# In produzione senza job in background usare `QUEUE_CONNECTION=sync` e NON impostare `COMPOSE_PROFILES` (nessun worker).
QUEUE_CONNECTION=database
COMPOSE_PROFILES=queue

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Google reCAPTCHA v3 (registrazione anti-bot). Chiavi da Google Admin; in locale lasciare vuoto finché non configuri.
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# Soglia minima score nella fascia "pass" (allineata al piano: oltre la fascia challenge, tipicamente 0.6).
RECAPTCHA_MIN_SCORE=0.6
# Timeout chiamata verifica server-to-server (millisecondi).
RECAPTCHA_TIMEOUT_MS=5000
# Log diagnostico in storage/logs dopo siteverify Google OK (score non in fascia block). In APP_ENV=local è attivo anche senza questa riga.
# RECAPTCHA_LOG_SITEVERIFY_SUCCESS=true

# Domini email aggiuntivi da bloccare alla registrazione (usa-e-getta), separati da virgola. Si sommano a config/registration.php.
# REGISTRATION_BLOCKED_EMAIL_DOMAINS=example-temp.com,another.net

VITE_APP_NAME="${APP_NAME}"
