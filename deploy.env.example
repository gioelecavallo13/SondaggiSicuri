# Copiare questo file in `deploy.env` nella root del repo e personalizzare.
# `deploy.env` è in `.gitignore` e non va committato.
#
# Vincoli: non usare DEPLOY_PATH sotto `/data/` (i dati persistenti restano fuori dal tree rsync).
#
# Sulla VPS, nel `.env` applicativo accanto al compose: con QUEUE_CONNECTION=database includere
# COMPOSE_PROFILES=queue (vedi `.env.example`). Con `sync` omettere COMPOSE_PROFILES.

# Utente e host SSH (es. deploy@esempio.tld)
DEPLOY_HOST=

# Directory sulla VPS dove risiede il clone del progetto (default consigliato)
DEPLOY_PATH=/opt/sondaggi

# --- SSH (opzionale) ---
SSH_PORT=22
# Chiave privata locale, se diversa dall’agent (percorso assoluto consigliato)
# SSH_IDENTITY_FILE=${HOME}/.ssh/id_ed25519

# --- Docker sulla VPS ---
# Se il login remoto deve usare `sudo docker compose`:
USE_SUDO_DOCKER=false

# File di configurazione deploy da caricare (default: ./deploy.env nella root repo)
# DEPLOY_ENV=/percorso/deploy.env
